{
  "$id": "https://github.com/SuperMonster003/AutoJs6-Shared-Assets/blob/main/ace-fonts/schemas/catalog-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "catalogVersion": {
      "minimum": 1,
      "type": "integer"
    },
    "fonts": {
      "items": {
        "$ref": "#/$defs/font"
      },
      "minItems": 1,
      "type": "array"
    },
    "minHostVersionCode": {
      "minimum": 1,
      "type": "integer"
    },
    "releaseTag": {
      "pattern": "^ace-fonts-v[1-9][0-9]*$",
      "type": "string"
    },
    "repository": {
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    }
  },
  "required": [
    "schemaVersion",
    "catalogVersion",
    "minHostVersionCode",
    "releaseTag",
    "repository",
    "fonts"
  ],
  "title": "AutoJs6 Ace font catalog v1",
  "type": "object",
  "$defs": {
    "artifact": {
      "additionalProperties": false,
      "properties": {
        "fileName": {
          "pattern": "^autojs6-ace-font-[a-z][a-z0-9_]{1,63}-v[1-9][0-9]*-[0-9a-f]{8}\\.woff2$",
          "type": "string"
        },
        "format": {
          "const": "woff2"
        },
        "mimeType": {
          "const": "font/woff2"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size": {
          "minimum": 1,
          "type": "integer"
        },
        "style": {
          "const": "normal"
        },
        "url": {
          "format": "uri",
          "pattern": "^https://github\\.com/.+/releases/download/ace-fonts-v[1-9][0-9]*/.+$",
          "type": "string"
        },
        "urls": {
          "items": {
            "format": "uri",
            "pattern": "^https://",
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        },
        "weight": {
          "const": 400
        }
      },
      "required": [
        "version",
        "fileName",
        "format",
        "mimeType",
        "weight",
        "style",
        "size",
        "sha256",
        "url",
        "urls"
      ],
      "type": "object"
    },
    "font": {
      "additionalProperties": false,
      "properties": {
        "artifact": {
          "$ref": "#/$defs/artifact"
        },
        "author": {
          "minLength": 1,
          "type": "string"
        },
        "displayName": {
          "minLength": 1,
          "type": "string"
        },
        "family": {
          "minLength": 1,
          "type": "string"
        },
        "features": {
          "description": "Explicit filter metadata. Absence in historical catalogs is equivalent to an empty array.",
          "items": {
            "enum": [
              "nerd",
              "variable",
              "cn"
            ],
            "type": "string"
          },
          "maxItems": 3,
          "type": "array",
          "uniqueItems": true
        },
        "id": {
          "not": {
            "enum": [
              "system_monospace",
              "iosevka"
            ]
          },
          "pattern": "^[a-z][a-z0-9_]{1,63}$",
          "type": "string"
        },
        "license": {
          "$ref": "#/$defs/license"
        },
        "order": {
          "minimum": 0,
          "type": "integer"
        },
        "source": {
          "$ref": "#/$defs/source"
        }
      },
      "required": [
        "id",
        "displayName",
        "family",
        "order",
        "author",
        "license",
        "source",
        "artifact"
      ],
      "type": "object"
    },
    "license": {
      "additionalProperties": false,
      "properties": {
        "files": {
          "items": {
            "$ref": "#/$defs/noticeFile"
          },
          "minItems": 1,
          "type": "array"
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "spdx": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name",
        "spdx",
        "files"
      ],
      "type": "object"
    },
    "noticeFile": {
      "additionalProperties": false,
      "properties": {
        "fileName": {
          "pattern": "^autojs6-ace-font-[a-z][a-z0-9_]{1,63}-v[1-9][0-9]*-[A-Za-z0-9._-]+$",
          "type": "string"
        },
        "originalName": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size": {
          "minimum": 1,
          "type": "integer"
        },
        "url": {
          "format": "uri",
          "pattern": "^https://github\\.com/.+/releases/download/ace-fonts-v[1-9][0-9]*/.+$",
          "type": "string"
        }
      },
      "required": [
        "fileName",
        "originalName",
        "size",
        "sha256",
        "url"
      ],
      "type": "object"
    },
    "snapshot": {
      "additionalProperties": false,
      "properties": {
        "commit": {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "versionCode": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "versionCode",
        "commit",
        "path"
      ],
      "type": "object"
    },
    "source": {
      "additionalProperties": false,
      "properties": {
        "autoJs6Snapshot": {
          "$ref": "#/$defs/snapshot"
        },
        "repository": {
          "format": "uri",
          "pattern": "^https://github\\.com/",
          "type": "string"
        },
        "upstreamVersion": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "repository",
        "upstreamVersion"
      ],
      "type": "object"
    }
  }
}
